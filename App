    fig.add_annotation(x=60, y=0, text="Mod/High", showarrow=False,
                       font={"size": 8, "color": "#4a6080"}, yref="paper")

    fig.update_layout(
        title={"text": "Toxicity Risk Profile — All 12 Assays", "font": {"size": 14, "color": "#8ba4c4", "family": "Space Mono"}},
