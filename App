    ))

    # Add threshold lines
    fig.add_vline(x=30, line_dash="dash", line_color="rgba(16,185,129,0.4)", line_width=1)
    fig.add_vline(x=60, line_dash="dash", line_color="rgba(239,68,68,0.4)", line_width=1)
